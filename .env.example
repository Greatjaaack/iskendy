# Пароль персонала для экрана кассы. Пустой = вход выключен.
STAFF_PASSWORD=

# Секрет подписи JWT. Если пусто — выводится из пароля (можно не задавать).
JWT_SECRET=
JWT_TTL_HOURS=24

# Часовой пояс ресторана (по нему считается «сегодня»).
TIMEZONE=Europe/Moscow

# Путь к SQLite-файлу.
DB_PATH=iskendy.db

# Дефолты нового дня.
DEFAULT_TOTAL_BATCHES=40
DEFAULT_START_TIME=12:00
DEFAULT_INTERVAL_MIN=15
BATCH_SIZE=7
